MOUSEKEY_ENABLE = yes       # Mouse keys
LTO_ENABLE = yes            # Link Time Optimization - reduces firmware size
COMBO_ENABLE = yes          # Key combo feature
CAPS_WORD_ENABLE = yes      # Caps word feature
SPLIT_KEYBOARD = yes        # Split keyboard support
REPEAT_KEY_ENABLE = yes     # Key repeat feature
TRI_LAYER_ENABLE = yes      # Enable built-in tri-layer support

# Memory optimization
CONSOLE_ENABLE = no         # Disable console for debug
COMMAND_ENABLE = no         # Disable command features
SPACE_CADET_ENABLE = no     # Disable space cadet shifts to save space
GRAVE_ESC_ENABLE = no       # Disable grave escape to save space
MAGIC_ENABLE = no           # Disable magic keycodes
MUSIC_ENABLE = no           # Disable music mode

# You may need to disable these if still having memory issues
# RGBLIGHT_ENABLE = no      # Disable RGB lighting if present
# AUDIO_ENABLE = no         # Disable audio features if present
